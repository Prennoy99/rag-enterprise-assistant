POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
OPENAI_API_KEY=sk-your-key-here
ENVIRONMENT=development

# TEMPORARY (branch experiment/gemini-temp only) - lets the app use a free Gemini API
# key (from aistudio.google.com) instead of OpenAI while testing. Leave LLM_PROVIDER
# unset/"openai" to use OpenAI as normal; this whole block is not meant to reach main.
LLM_PROVIDER=gemini
GOOGLE_API_KEY=your-gemini-api-key-here
VITE_API_URL=http://localhost:8000

# Shared secret required on every /api/v1/* request via the X-API-Key header.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-to-a-random-secret
VITE_API_KEY=change-me-to-a-random-secret
