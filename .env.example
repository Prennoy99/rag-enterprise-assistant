POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
ENVIRONMENT=development
VITE_API_URL=http://localhost:8000

# Which LLM provider serves embeddings/chat: "openai" or "gemini". Only the active
# provider's key below needs to be set.
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here

# Gemini alternative - get a free key at aistudio.google.com (separate from any paid
# Google AI subscription, which does not grant API access). Set LLM_PROVIDER=gemini
# above to use this instead.
GOOGLE_API_KEY=your-gemini-api-key-here

# Shared secret required on every /api/v1/* request via the X-API-Key header.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-to-a-random-secret
VITE_API_KEY=change-me-to-a-random-secret
